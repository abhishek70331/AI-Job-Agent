const axios = require("axios");
const { query } = require("./db");

/**
 * Extract company slug from Lever URL
 * Example: https://jobs.lever.co/welocalize → welocalize
 */
function extractCompany(boardUrl) {
  const parts = boardUrl.split("/");
  return parts[parts.length - 1] || parts[parts.length - 2];
}

/**
 * Fetch jobs from Lever API and save to database
 */
async function fetchLeverJobs(boardUrl) {

  if (!boardUrl || typeof boardUrl !== "string") {
    throw new Error("A valid Lever board URL string is required");
  }

  const company = extractCompany(boardUrl);

  const apiUrl = `https://api.lever.co/v0/postings/${company}?mode=json`;

  try {

    const response = await axios.get(apiUrl);

    const jobs = response.data.map(job => ({
      title: job.text,
      team: job.categories?.team || "",
      location: job.categories?.location || "",
      url: job.hostedUrl,
      source: "lever",
      description: job.descriptionPlain || ""
    }));


    // Save jobs to database
    for (const job of jobs) {

      await query(
        `
        INSERT INTO jobs (title, team, location, url, source)
        VALUES ($1,$2,$3,$4,$5)
        ON CONFLICT (url) DO NOTHING
        `,
        [
          job.title,
          job.team,
          job.location,
          job.url,
          job.source
        ]
      );
      // await query(
      //   `
      //   INSERT INTO jobs (title, team, location, url, source, description)
      //   VALUES ($1,$2,$3,$4,$5,$6)
      //   ON CONFLICT (url) DO NOTHING
      //   `,
      //   [
      //     job.title,
      //     job.team,
      //     job.location,
      //     job.url,
      //     job.source,
      //     job.description
      //   ]
      // );

    }

    return jobs;

  } catch (error) {

    console.error("Lever API error:", error.message);

    throw new Error("Failed to fetch jobs");

  }
}

module.exports = {
  fetchLeverJobs
};

